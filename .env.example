# Credenciales de Supabase
# Las encontrás en: Supabase Dashboard → Project Settings → Data API / API Keys
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Microservicio de IA (proyecto previtaly-ai, corre aparte con FastAPI).
# Si NO se define, el análisis cae automáticamente al mock local.
# AI_SERVICE_KEY debe coincidir con INTERNAL_API_KEY del .env de previtaly-ai.
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_KEY=cambia-esto-por-el-mismo-secreto-del-ai-service
